# Copy this file to .env, then run `npm run setup`.
# Never commit .env. Replace every placeholder before enabling the bridge.

# Identity and branding
LARK_CODEX_ASSISTANT_NAME=Codex
LARK_CODEX_KNOWLEDGE_AGENT_NAME=Codex knowledge agent
LARK_CODEX_BOT_NAME=
LARK_CODEX_BOT_ALIASES=
LARK_CODEX_TRIGGER_PREFIX=/codex

# Access control. Keep ALLOW_ALL disabled for normal deployments.
LARK_CODEX_ALLOW_ALL=0
LARK_CODEX_ALLOWED_SENDERS=
LARK_CODEX_ALLOWED_CHATS=
LARK_CODEX_OWNER_MODE_ENABLED=1
LARK_CODEX_OWNER_SENDERS=
LARK_CODEX_OWNER_TRIGGERS=/codex

# Codex execution
LARK_CODEX_WORKDIR=.
LARK_CODEX_SANDBOX=workspace-write
LARK_CODEX_MODEL=
# Execution engine: "codex" (default) or "claude". The "claude" engine shells
# out to the `claude` CLI, which must be installed and authenticated separately
# (run `claude` once and `/login`, or set ANTHROPIC_API_KEY). It runs with
# --permission-mode bypassPermissions and does not support image inputs.
LARK_CODEX_ENGINE=codex
# Optional model override for the claude engine (e.g. a Claude model name).
# LARK_CODEX_MODEL applies to the codex engine only; the two are separate
# because their model ids are not interchangeable.
LARK_CODEX_CLAUDE_MODEL=
LARK_CODEX_EXTRA_ARGS=
LARK_CODEX_EXEC_TIMEOUT_MS=1800000
LARK_CODEX_APPROVAL_POLICY=never
LARK_CODEX_SESSION_BACKEND=app-server
LARK_CODEX_APP_SERVER_APPROVAL_POLICY=never
LARK_CODEX_APP_SERVER_TIMEOUT_MS=1800000

# Optional owner knowledge-source hints. Skills are comma-separated names from
# ~/.codex/skills, without the leading `$`.
LARK_CODEX_KNOWLEDGE_SKILLS=
LARK_CODEX_KNOWLEDGE_BASE_NAME=configured knowledge sources
LARK_CODEX_KNOWLEDGE_BASE_HINT=
LARK_CODEX_SSH_HELPER=./scripts/ssh-exec.exp

# Replies and start indicators
LARK_CODEX_REPLY_IN_THREAD=0
LARK_CODEX_MAX_REPLY_CHARS=3500
LARK_CODEX_STARTED_REPLY_ENABLED=0
LARK_CODEX_STARTED_REACTION_ENABLED=1
LARK_CODEX_STARTED_REACTION=Typing
LARK_CODEX_STARTED_REACTION_AS=bot
LARK_CODEX_P2P_NO_PREFIX=0
LARK_CODEX_GROUP_NO_PREFIX=0

# Progress and native dynamic cards
LARK_CODEX_PROGRESS_ENABLED=1
LARK_CODEX_PROGRESS_INITIAL_DELAY_SECONDS=20
LARK_CODEX_PROGRESS_INTERVAL_SECONDS=30
LARK_CODEX_PROGRESS_MAX_UPDATES=12
LARK_CODEX_DYNAMIC_CARD_ENABLED=1
LARK_CODEX_DYNAMIC_CARD_UPDATE_INTERVAL_SECONDS=3
LARK_CODEX_DYNAMIC_CARD_MAX_EVENTS=8
LARK_CODEX_DYNAMIC_CARD_TASK_CHARS=900
LARK_CODEX_DYNAMIC_CARD_EVENT_CHARS=700
LARK_CODEX_DYNAMIC_CARD_FINAL_CHARS=2000
LARK_CODEX_DYNAMIC_CARD_SUPPRESS_PROGRESS_MESSAGES=1

# Optional localhost-only run viewer. Keep SEND_CARD=0 unless PUBLIC_BASE_URL is
# actually reachable by every intended recipient.
LARK_CODEX_RUN_VIEWER_ENABLED=1
LARK_CODEX_RUN_VIEWER_HOST=127.0.0.1
LARK_CODEX_RUN_VIEWER_PORT=8765
LARK_CODEX_RUN_VIEWER_PUBLIC_BASE_URL=
LARK_CODEX_RUN_VIEWER_SEND_CARD=0

# Whitelisted colleague P2P knowledge-agent mode
LARK_CODEX_P2P_AUTO_REPLY_ENABLED=0
LARK_CODEX_P2P_AUTO_REPLY_ALLOWED_SENDERS=
LARK_CODEX_P2P_AUTO_REPLY_POLL_SECONDS=30
LARK_CODEX_P2P_AUTO_REPLY_LOOKBACK_SECONDS=300
LARK_CODEX_P2P_AUTO_REPLY_MAX_MESSAGES_PER_POLL=3
LARK_CODEX_P2P_AUTO_REPLY_REQUIRE_TRIGGER=1
LARK_CODEX_P2P_AUTO_REPLY_TRIGGERS=/ask-codex
LARK_CODEX_P2P_AUTO_REPLY_SEND_AS=bot
LARK_CODEX_P2P_AUTO_REPLY_PREFIX=[Codex knowledge agent auto-reply]
LARK_CODEX_P2P_AUTO_REPLY_STARTED_REACTION_ENABLED=1
LARK_CODEX_P2P_AUTO_REPLY_STARTED_REACTION=Typing

# Friendly aliases and direct P2P chat routing:
# Alice=ou_example,Bob=ou_example2
# Alice=oc_example,Bob=oc_example2
LARK_CODEX_P2P_AUTO_REPLY_SENDER_NAMES=
LARK_CODEX_P2P_AUTO_REPLY_SENDER_CHATS=
LARK_CODEX_P2P_AUTO_REPLY_SESSION_MODE=per_sender
LARK_CODEX_P2P_AUTO_REPLY_SESSION_ALIAS_PREFIX=codex-p2p
LARK_CODEX_P2P_AUTO_REPLY_SESSION_WORKDIR=.
LARK_CODEX_P2P_AUTO_REPLY_SESSION_BACKEND=app-server
LARK_CODEX_P2P_AUTO_REPLY_SESSION_SANDBOX=read-only
LARK_CODEX_P2P_AUTO_REPLY_SESSION_MODEL=

# Owner commands inside configured colleague P2P chats
LARK_CODEX_P2P_OWNER_TRIGGER_ENABLED=0
LARK_CODEX_P2P_OWNER_TRIGGER_PREFIX=

# Optional response for non-whitelisted P2P trigger attempts
LARK_CODEX_P2P_UNAUTHORIZED_REPLY_ENABLED=0
LARK_CODEX_P2P_UNAUTHORIZED_REPLY_TRIGGERS=/ask-codex
LARK_CODEX_P2P_UNAUTHORIZED_REPLY_MESSAGE=You are not authorized to use this knowledge agent. Contact its owner.

# macOS LaunchAgent label
LARK_CODEX_LAUNCHD_LABEL=io.codex-lark.bridge

# Optional proxy inherited by lark-cli and Codex child processes
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1
